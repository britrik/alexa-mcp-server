# Alexa MCP Server - Minimal Setup
# Keep all secrets local or in Cloudflare Secrets/KV. Never commit real cookie values.

# REQUIRED: Alexa configuration
ALEXA_BASE_URL="https://alexa.amazon.co.uk"
ALEXAMARKETPLACEID="A1F8U5RK5OH7Y3"

# REQUIRED: Amazon ubid-main cookie (paste your local browser value here)
UBID_MAIN="<paste-ubid-main-here>"

# REQUIRED: Amazon at-main auth token (paste your local browser value here)
AT_MAIN="<paste-at-main-here>"

# REQUIRED: Shared secret used by the Playwright rotation script to authorize /update-session
UPDATE_SESSION_TOKEN="change-me"

# REQUIRED: Fully qualified Worker URL for session rotation
UPDATE_SESSION_URL="https://your-deployment.workers.dev/update-session"

# REQUIRED: Encryption key used by the Worker to protect rotated cookies in KV
SESSION_ENCRYPTION_KEY="change-me-to-a-long-random-secret"

# OPTIONAL: TTL for encrypted cookies stored in KV, in seconds
SESSION_KV_TTL_SECONDS="1209600"

# OPTIONAL: Local browser profile directory used by the Playwright rotation script
PLAYWRIGHT_USER_DATA_DIR=".playwright/alexa-session"

# API Configuration
API_BASE="https://your-deployment.workers.dev"
